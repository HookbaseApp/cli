// IMPORTANT: signature verification needs the *raw* body bytes, not a parsed
// object. express.raw gives us the buffer; we parse JSON ourselves after.
app.post('/webhook', express.raw({ type: '*/*' }), (req, res) => {
  const rawBody = req.body.toString('utf8');
  const signature = req.headers['{{HEADER_NAME}}'];
  const timestamp = req.headers['x-slack-request-timestamp']; // only used by Slack

  if (!signature) {
    return res.status(401).json({ error: 'missing signature header' });
  }

  const ok = verifySignature(rawBody, signature, SIGNING_SECRET, timestamp);
  if (!ok) {
    return res.status(401).json({ error: 'invalid signature' });
  }

  let payload;
  try { payload = JSON.parse(rawBody); } catch { payload = {}; }

  console.log('Received event:', payload.type || payload.event || 'unknown');
  res.status(200).json({ received: true });
});

app.listen(PORT, () => {
