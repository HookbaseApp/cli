import { NextResponse } from 'next/server';
import * as crypto from 'crypto';

export const runtime = 'nodejs';
export const dynamic = 'force-dynamic';

const SIGNING_SECRET = process.env.{{ENV_VAR_NAME}} || '';

{{VERIFY_SNIPPET}}

export async function POST(request: Request) {
  // Use request.text() to keep the raw bytes the signature was computed over.
  const rawBody = await request.text();
  const signature = request.headers.get('{{HEADER_NAME}}') || '';
  const timestamp = request.headers.get('x-slack-request-timestamp') || '';

  if (!signature) {
    return NextResponse.json({ error: 'missing signature header' }, { status: 401 });
  }

  const ok = verifySignature(rawBody, signature, SIGNING_SECRET, timestamp);
  if (!ok) {
    return NextResponse.json({ error: 'invalid signature' }, { status: 401 });
  }

  let payload: any;
  try { payload = JSON.parse(rawBody); } catch { payload = {}; }

  console.log('Received event:', payload.type || payload.event || 'unknown');
  return NextResponse.json({ received: true });
}
