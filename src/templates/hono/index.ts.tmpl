import { Hono } from 'hono';
import { serve } from '@hono/node-server';
import * as crypto from 'crypto';

const app = new Hono();
const PORT = Number(process.env.PORT) || 3000;
const SIGNING_SECRET = process.env.{{ENV_VAR_NAME}} || '';

if (!SIGNING_SECRET) {
  console.warn('Warning: {{ENV_VAR_NAME}} not set — signature verification will fail.');
}

{{VERIFY_SNIPPET}}

app.post('/webhook', async (c) => {
  const rawBody = await c.req.text();
  const signature = c.req.header('{{HEADER_NAME}}');
  const timestamp = c.req.header('x-slack-request-timestamp');

  if (!signature) {
    return c.json({ error: 'missing signature header' }, 401);
  }

  const ok = verifySignature(rawBody, signature, SIGNING_SECRET, timestamp);
  if (!ok) {
    return c.json({ error: 'invalid signature' }, 401);
  }

  let payload: any;
  try { payload = JSON.parse(rawBody); } catch { payload = {}; }

  console.log('Received event:', payload.type || payload.event || 'unknown');
  return c.json({ received: true });
});

serve({ fetch: app.fetch, port: PORT });
console.log(`{{PROVIDER_LABEL}} webhook handler listening on http://localhost:${PORT}/webhook`);
